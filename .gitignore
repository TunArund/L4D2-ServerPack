# ============================================================
# 游戏资产 — 不进 Git，本地维护
# ============================================================
l4d2/src/

# ============================================================
# 环境变量（含密钥）
# ============================================================
.env

# ============================================================
# Docker 运行时数据（bind-mount 目录内容）
# ============================================================
mysql/data/*
!mysql/data/.gitkeep
l4d2/data/coop/addons/*
!l4d2/data/coop/addons/.gitkeep
l4d2/data/coop/ems/*
!l4d2/data/coop/ems/.gitkeep
l4d2/data/coop/cfg/*
!l4d2/data/coop/cfg/.gitkeep
l4d2/data/coop/scripts/*
!l4d2/data/coop/scripts/.gitkeep
l4d2/data/coop/host.txt
l4d2/data/coop/motd.txt
l4d2/data/versus/addons/*
!l4d2/data/versus/addons/.gitkeep
l4d2/data/versus/ems/*
!l4d2/data/versus/ems/.gitkeep
l4d2/data/versus/cfg/*
!l4d2/data/versus/cfg/.gitkeep
l4d2/data/versus/scripts/*
!l4d2/data/versus/scripts/.gitkeep
l4d2/data/versus/host.txt
l4d2/data/versus/motd.txt
web/data/logs/*
!web/data/logs/.gitkeep
nginx/data/certs/*
!nginx/data/certs/.gitkeep

# ============================================================
# 开发工具（仅 dev 分支使用，main 分支忽略）
# ============================================================
docker-compose.dev.yml
php-dev.sh
