# ============================================================
# 🔴 必改 — 安全凭据（所有 change_me 必须替换）
# ============================================================
# 随机密码生成指令: openssl rand -hex 16
# 可任意更改末尾数字，对应密码长度
# MySQL root 密码
MYSQL_ROOT_PASSWORD=change_me

# MySQL 应用库密码（php + downloader 连接用）
MYSQL_PASSWORD=change_me

# 内部 API 认证令牌（sidecar + 每日更新 token 认证）
SIDECAR_TOKEN=change_me

# 腾讯云API密钥(cam api key建议使用子账户，仅授予必要权限)
# 获取: https://console.cloud.tencent.com/cam/capi
# 邮件推送服务(SES，注册用户时的邮箱验证码）
SES_SECRET_ID=change_me
SES_SECRET_KEY=change_me

# ============================================================
# 🟡 必改 — 环境适配（按实际路径和 uid/gid 修改）
# ============================================================

# 游戏文件目录（steamcmd 下载目标，bind mount 进 l4d2 容器）
GAME_DIR=/home/steam/L4D2-ServerPack/l4d2/src

# 容器运行用户（必须与 GAME_DIR owner 一致，否则 SourceMod Permission denied）
# 查看目录所有者: ls -ld <GAME_DIR>
# 查看用户与组ID: id -u <username>; id -g <username>
APP_UID=1002
APP_GID=1003

# ============================================================
# 🟢 可选 — MySQL
# ============================================================

MYSQL_DATABASE=steam
MYSQL_USER=steam

# ============================================================
# 🟢 可选 — 腾讯云 COS（地图 CDN 分发）
# ============================================================
# 不配置则跳过 COS 上传，地图仅能通过 Steam CDN 下载
# COS获取: https://console.cloud.tencent.com/cos/bucket → 存储桶列表 → 配置管理
# SecretId/SecretKey 同 CAM API 密钥，也可单独创建子账号

# COS_SECRET_ID=change_me
# COS_SECRET_KEY=change_me
# COS_BUCKET=your-bucket-id
# COS_REGION=ap-guangzhou
# COS_CUSTOM_DOMAIN=http://cdn.example.com     # 可选: CDN 加速域名

# ============================================================
# 🟢 可选 — 镜像构建 & CI/CD
# ============================================================

# 镜像仓库前缀（开发留空，推送 GitHub 时设 ghcr.io/<user>/）
REGISTRY=

# 容器时区（构建时烘焙进镜像，运行时不变）
# 常用: Asia/Shanghai, Asia/Tokyo, America/New_York, Europe/Berlin
TZ=Asia/Shanghai

# Alpine 包镜像源（国内用 mirrors.aliyun.com，海外留空走官方源）
# 备选: mirrors.ustc.edu.cn / mirrors.tuna.tsinghua.edu.cn
APK_MIRROR=mirrors.aliyun.com

# GitHub 凭据（仅 docker.sh push 时需要）
# Settings → Developer settings → Personal access tokens → Classic
# 勾选 write:packages, delete:packages
GITHUB_USER=change_me
GITHUB_TOKEN=change_me

# ============================================================
# 🟢 可选 — L4D2 游戏服务器
# ============================================================

# 对外端口（默认 27015 / 27014，冲突时修改）
# L4D2_PORT=27015
# L4D2_VERSUS_PORT=27014

# srcds 启动参数（已有默认值，需覆盖时取消注释）
# L4D2_COOP_ARGS=+ip 0.0.0.0 -port 27015 +sv_steam_bypass 1 +sv_setmax 32 +map c2m1_highway +z_difficulty normal +exec server.cfg -tickrate 100
# L4D2_VERSUS_ARGS=+ip 0.0.0.0 -port 27015 +sv_clockcorrection_msecs 25 -timeout 2 -tickrate 100 +mp_gamemode versus +map c1m1_hotel -maxplayers 32 +exec server.cfg

# ============================================================
# 🟢 可选 — 容器管理 (sidecar)
# ============================================================

# 白名单（已有默认值，需覆盖时取消注释）
# ALLOWED_CONTAINERS=l4d2-downloader,l4d2-coop,l4d2-versus,l4d2-php,l4d2-mysql,l4d2-glances,l4d2-nginx
# RESTARTABLE_CONTAINERS=l4d2-downloader,l4d2-coop,l4d2-versus

# ============================================================
# 🟢 可选 — 下载器 & 日志
# ============================================================

# 地图下载目录（downloadler 下载 vpk 的目标路径）
# MAP_DIR=/var/www/addons/workshop/

# 日志目录（PHP 错误日志 + downloader 守护进程日志）
# LOG_DIR=/var/www/html/logs/
