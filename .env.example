# ============================================================
# GitHub Container Registry
# ============================================================
# - 开发环境留空 → docker compose build 本地构建
# - 推送/生产时填入完整路径（末尾带 /）
REGISTRY=

# GitHub 凭据（仅 docker.sh 推送时需要）
# GitHub → Settings → Developer settings → Personal access tokens
# → Tokens (classic) → Generate new token → 勾选 write:packages, delete:packages
GITHUB_USER=change_me
GITHUB_TOKEN=change_me

# ============================================================
# 必填
# ============================================================

# 游戏文件目录（远端 bind mount 路径）
GAME_DIR=/home/steam/l4d2server

# 容器运行用户 UID/GID（必须与游戏文件 owner 一致，否则 Permission denied）
# 运行 id -u 和 id -g 查看当前用户的值
UID=1000
GID=1000

# MySQL
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=steam
MYSQL_USER=steam
MYSQL_PASSWORD=change_me

# 腾讯云 SES 邮件服务 API 密钥
# 前往 https://console.cloud.tencent.com/cam/capi 获取
TENCENTCLOUD_SECRET_ID=change_me
TENCENTCLOUD_SECRET_KEY=change_me

# 容器管理 API 认证令牌（生产环境必须设置）
# 生成: openssl rand -hex 16
SIDECAR_TOKEN=change_me

# ============================================================
# 可选（已有默认值，需要覆盖时取消注释）
# ============================================================

# 地图下载器
# MAP_DIR=/var/www/addons/workshop/
# LOG_DIR=/var/www/html/logs/

# 容器管理：允许在面板查看的容器
# ALLOWED_CONTAINERS=l4d2-downloader,l4d2-coop,l4d2-versus,l4d2-php,l4d2-mysql,l4d2-glances,l4d2-nginx

# 容器管理：允许重启的容器（应为 ALLOWED 子集）
# RESTARTABLE_CONTAINERS=l4d2-downloader,l4d2-coop,l4d2-versus

# L4D2 对外端口（宿主机 → 容器内 27015）
# L4D2_PORT=27015
# L4D2_VERSUS_PORT=27014

# L4D2 战役服启动参数
# L4D2_COOP_ARGS=+ip 0.0.0.0 -port 27015 +sv_steam_bypass 1 +sv_setmax 32 +map c2m1_highway +z_difficulty normal +exec server.cfg -tickrate 100

# L4D2 对抗服启动参数
# L4D2_VERSUS_ARGS=+ip 0.0.0.0 -port 27015 +sv_steam_bypass 1 +sv_setmax 32 +map c2m1_highway +z_difficulty normal +exec server.cfg -tickrate 100
